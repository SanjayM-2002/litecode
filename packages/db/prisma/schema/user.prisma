enum Role {
  PARTICIPANT
  ADMIN
}

enum Permission {
  CREATE_PROBLEM
  EDIT_PROBLEM
  MANAGE_USERS
  CREATE_CONTEST
  MANAGE_TEMPLATES
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  role      Role     @default(PARTICIPANT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participantProfile       ParticipantProfile?
  adminProfile             AdminProfile?
  sentAdminInvitations     AdminInvitation[]   @relation("InvitedAdmins")
  acceptedAdminInvitations AdminInvitation[]   @relation("AcceptedInvitations")

  @@index([role])
}

model AdminProfile {
  id     String @id @default(cuid())
  userId String @unique

  permissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminInvitation {
  id          String           @id @default(cuid())
  email       String
  tokenHash   String           @unique
  permissions Permission[]
  status      InvitationStatus @default(PENDING)

  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  invitedById      String
  acceptedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitedBy      User  @relation("InvitedAdmins", fields: [invitedById], references: [id])
  acceptedByUser User? @relation("AcceptedInvitations", fields: [acceptedByUserId], references: [id])

  @@index([email])
  @@index([status])
}
