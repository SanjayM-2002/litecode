{
  "name": "@litecode/db",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "migrate": "prisma migrate dev --schema=./prisma/schema",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema",
    "migrate:reset": "prisma migrate reset --schema=./prisma/schema",
    "generate": "prisma generate --schema=./prisma/schema",
    "studio": "prisma studio --schema=./prisma/schema"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prisma": "^5.0.0",
    "typescript": "^5.7.3"
  }
}
